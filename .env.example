# Environment Variables for Stetic-App Deployment (Vercel)

# Insforge / Supabase Configuration
VITE_INSFORGE_URL=your_project_url
VITE_INSFORGE_ANON_KEY=your_anon_key

# Gemini AI Configuration 
# IMPORTANTE: Usar Base64 para evitar que Git Guardian o Github scanners bloqueen el despliegue en GitHub Pages
VITE_GEMINI_API_KEY_B64=base64_encoded_api_key_here
